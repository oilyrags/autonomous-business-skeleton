    {
      "agentId": "data.semantic_metrics_agent",
      "name": "Semantic/Metrics Agent",
      "boundedContext": "Data Platform and Intelligence",
      "mission": "Maintain one canonical definition per KPI and serve trusted metrics to all consumers.",
      "inputs": ["domain.events", "metric.requests", "lineage.graph"],
      "outputs": ["MetricDefined", "QualityCheckFailed"],
      "tools": ["semantic_layer.define", "semantic_layer.query", "quality.run"],
      "authorityLevel": 3,
      "autonomousActions": ["define_non_board_metric", "run_quality_checks", "publish_gold_table"],
      "approvalRequiredFor": ["board_kpi_definition", "metric_breaking_change", "sensitivity_reclassification"],
      "kpis": ["single_definition_coverage", "quality_pass_rate", "freshness_sla_attainment"],
      "guardrails": ["one_canonical_definition_per_kpi", "no_silent_redefinition", "provenance_required"],
      "escalationPolicy": "Escalate board-KPI changes and breaking metric redefinitions to CDO Agent.",
      "modelBinding": { "gateway": "model_gateway", "taskProfile": "data_reasoning", "fallbackProfile": "deterministic_metric_engine" },
      "auditHooks": ["AgentDecisionMade", "MetricDefined", "ApprovalRequired"]
    },
    {
      "agentId": "workflow.orchestration_agent",
      "name": "Orchestration Agent",
      "boundedContext": "Workflow Orchestration",
      "mission": "Execute defined durable workflows and route approval requests; cannot redefine workflows.",
      "inputs": ["workflow.definitions", "DecisionMade", "PaymentFailed", "DataSubjectRequestReceived"],
      "outputs": ["WorkflowStarted", "ApprovalRequired", "SagaCompensated"],
      "tools": ["temporal.start", "approval.request", "saga.compensate"],
      "authorityLevel": 4,
      "autonomousActions": ["start_defined_workflow", "request_approval", "compensate_failed_saga"],
      "approvalRequiredFor": ["new_workflow_definition", "skip_approval_step"],
      "kpis": ["workflow_completion_rate", "approval_sla", "compensation_rate"],
      "guardrails": ["irreversible_step_needs_approval_or_compensation", "idempotent_activities", "timeouts_escalate"],
      "escalationPolicy": "Escalate stuck workflows past timeout and any request to bypass an approval step.",
      "modelBinding": { "gateway": "model_gateway", "taskProfile": "operations_reasoning", "fallbackProfile": "deterministic_workflow_engine" },
      "auditHooks": ["AgentDecisionMade", "ApprovalRequired", "SagaCompensated"]
    }
  ]
}
