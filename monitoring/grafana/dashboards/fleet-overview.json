{
  "uid": "ab-fleet",
  "title": "Autonomous Business — Fleet Overview",
  "tags": ["fleet", "business"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Businesses",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{ "expr": "ab_fleet_businesses", "refId": "A" }]
    },
    {
      "id": 2,
      "title": "Fleet operating profit (minor)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 4, "y": 0 },
      "targets": [{ "expr": "ab_fleet_operating_profit_minor", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Unprofitable businesses",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 9, "y": 0 },
      "targets": [{ "expr": "ab_fleet_unprofitable", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Error budget burn",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 5, "x": 13, "y": 0 },
      "targets": [{ "expr": "ab:error_budget_burn:ratio", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Operating profit by business (minor)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "ab_business_operating_profit_minor",
          "legendFormat": "{{business_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Check status (0 OK · 1 WARN · 2 CRIT)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{ "expr": "ab_check_status", "format": "table", "instant": true, "refId": "A" }]
    },
    {
      "id": 7,
      "title": "LLM cost as share of revenue (bps)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "ab_business_llm_cost_ratio_bps",
          "legendFormat": "{{business_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Revenue by business (minor)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "ab_business_revenue_minor",
          "legendFormat": "{{business_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Experiment win rate (bps)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "ab_experiment_win_rate_bps",
          "legendFormat": "{{business_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Open experiments by business",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "ab_experiment_open",
          "legendFormat": "{{business_id}}",
          "refId": "A"
        }
      ]
    }
  ]
}
