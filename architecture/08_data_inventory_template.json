{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "inventoryVersion": "1.0.0",
  "purpose": "Seed Record of Processing Activities (RoPA, GDPR Art.30) + DSAR routing map. Every personal-data element MUST have an entry. CI fails if a `personal`-classified event/field has no matching record. retentionPolicy ids are referenced by 04_event_catalog and 07_data_model.",
  "retentionPolicies": {
    "consent_retention": "Life of relationship + 6y after last contact (proof of consent/withdrawal).",
    "contact_retention": "Active + 24 months after last engagement, then erase/anonymize.",
    "support_retention": "Active + 24 months, then anonymize conversation content.",
    "financial_retention": "10 years (legal_obligation — tax/accounting). Erasure blocked by legal basis.",
    "dsar_retention": "Proof of fulfilment kept 6 years; exported PII not retained beyond delivery.",
    "hr_retention": "Duration of employment + statutory period per jurisdiction.",
    "compliance_retention": "Per regulatory requirement; default 6 years.",
    "security_retention": "Audit/security logs 18 months hot + 5 years cold (immutable).",
    "decision_retention": "Life of company (governance record).",
    "ops_standard": "13 months.",
    "ops_long": "5 years.",
    "ops_short": "90 days.",
    "derived_short": "Regenerated; max 90 days.",
    "incident_retention": "5 years.",
    "ops_long_2": "see ops_long"
  },
  "records": [
    {
      "dataElement": "customer.email",
      "owningContext": "CRM and Marketing",
      "entity": "Contact",
      "classification": "personal",
      "lawfulBasis": "consent",
      "purpose": "Lifecycle communication and account management",
      "source": "signup_form",
      "processors": ["email_service", "crm_database"],
      "recipients": ["customer_service", "data_platform"],
      "retentionPolicy": "contact_retention",
      "dsarAccess": true,
      "dsarPortability": true,
      "erasureBehavior": "delete_or_anonymize_unless_legal_hold",
      "residency": "EU",
      "crossBorderTransfer": "none",
      "controls": ["encryption_at_rest", "access_logged", "purpose_limited_access"]
    },
    {
      "dataElement": "contact.consent_record",
      "owningContext": "CRM and Marketing",
      "entity": "Consent",
      "classification": "personal",
      "lawfulBasis": "consent",
      "purpose": "Proof of lawful basis for outreach by channel and purpose",
      "source": "consent_capture",
      "processors": ["crm_database", "consent_service"],
      "recipients": ["sales", "customer_service", "compliance", "data_platform"],
      "retentionPolicy": "consent_retention",
      "dsarAccess": true,
      "dsarPortability": true,
      "erasureBehavior": "retain_proof_anonymize_payload_unless_legal_hold",
      "residency": "EU",
      "crossBorderTransfer": "none",
      "controls": ["encryption_at_rest", "immutable_grant_revoke_log", "access_logged"]
    },
    {
      "dataElement": "lead.contact_details",
      "owningContext": "CRM and Marketing",
      "entity": "Lead",
      "classification": "personal",
      "lawfulBasis": "legitimate_interest",
      "purpose": "Qualify inbound interest prior to relationship",
      "source": "inbound_form | event | referral",
      "processors": ["crm_database"],
      "recipients": ["sales"],
      "retentionPolicy": "contact_retention",
      "dsarAccess": true,
      "dsarPortability": true,
      "erasureBehavior": "delete_unless_converted_then_contact_rules",
      "residency": "EU",
      "crossBorderTransfer": "none",
      "controls": ["LIA_documented", "access_logged", "objection_supported"]
    },
    {
      "dataElement": "account.billing_contact",
      "owningContext": "Finance, Accounting, Billing, and FP&A",
      "entity": "Invoice",
      "classification": "personal",
      "lawfulBasis": "contract",
      "purpose": "Issue and collect invoices",
      "source": "deal_won | contract",
      "processors": ["billing_engine", "ledger_db"],
      "recipients": ["customer_service"],
      "retentionPolicy": "financial_retention",
      "dsarAccess": true,
      "dsarPortability": false,
      "erasureBehavior": "blocked_by_legal_obligation_until_retention_expiry",
      "residency": "EU",
      "crossBorderTransfer": "none",
      "controls": ["encryption_at_rest", "append_only_ledger", "access_logged", "maker_checker"]
    },
    {
      "dataElement": "ticket.conversation_content",
      "owningContext": "Customer Service and Customer Success",
      "entity": "Conversation",
      "classification": "personal",
      "lawfulBasis": "contract",
      "purpose": "Provide and improve customer support",
      "source": "support_channel",
      "processors": ["ticketing_system", "retrieval_index"],
      "recipients": ["data_platform", "knowledge_management"],
      "retentionPolicy": "support_retention",
      "dsarAccess": true,
      "dsarPortability": true,
      "erasureBehavior": "anonymize_content_retain_metrics_unless_legal_hold",
      "residency": "EU",
      "crossBorderTransfer": "none",
      "controls": ["pii_redaction_in_index", "access_logged", "purpose_limited_access"]
    },
    {
      "dataElement": "user.hr_record",
      "owningContext": "People and Workforce",
      "entity": "User",
      "classification": "personal",
      "lawfulBasis": "contract",
      "purpose": "Employment administration and access lifecycle",
      "source": "onboarding",
      "processors": ["hr_system", "iam"],
      "recipients": ["security", "finance_payroll"],
      "retentionPolicy": "hr_retention",
      "dsarAccess": true,
      "dsarPortability": true,
      "erasureBehavior": "delete_after_statutory_period_unless_legal_hold",
      "residency": "EU",
      "crossBorderTransfer": "none",
      "controls": ["restricted_access", "encryption_at_rest", "access_logged"]
    },
    {
      "dataElement": "dsar.subject_identity",
      "owningContext": "Compliance, Privacy, and Legal",
      "entity": "DataSubjectRequest",
      "classification": "personal",
      "lawfulBasis": "legal_obligation",
      "purpose": "Fulfil and evidence data-subject rights",
      "source": "dsar_intake",
      "processors": ["compliance_system", "workflow_engine"],
      "recipients": ["all_personal_data_contexts"],
      "retentionPolicy": "dsar_retention",
      "dsarAccess": true,
      "dsarPortability": false,
      "erasureBehavior": "retain_fulfilment_proof_minimize_payload",
      "residency": "EU",
      "crossBorderTransfer": "none",
      "controls": ["identity_verification", "evidence_store", "access_logged"]
    },
    {
      "dataElement": "agent.trace_with_user_input",
      "owningContext": "AI Model Operations and Agent Platform",
      "entity": "Model",
      "classification": "personal",
      "lawfulBasis": "legitimate_interest",
      "purpose": "Debug, evaluate, and improve agent quality",
      "source": "agent_runtime",
      "processors": ["langfuse", "trace_store"],
      "recipients": ["security", "data_platform"],
      "retentionPolicy": "ops_standard",
      "dsarAccess": true,
      "dsarPortability": false,
      "erasureBehavior": "redact_pii_at_ingestion_then_delete_on_schedule",
      "residency": "EU",
      "crossBorderTransfer": "none",
      "controls": ["pii_redaction_at_ingestion", "access_logged", "no_pii_in_plaintext_logs"]
    }
  ],
  "validationRules": [
    "Every event in 04_event_catalog classified `personal` must map to >=1 record here.",
    "Every record must declare a lawfulBasis from the GDPR Art.6 enum.",
    "erasureBehavior must reconcile with retentionPolicy and any legal_obligation basis.",
    "dsarAccess and the chosen Subject Rights API behavior must be implementable by owningContext.",
    "crossBorderTransfer != 'none' requires a transferMechanism (adequacy/SCC) and Compliance review."
  ]
}
