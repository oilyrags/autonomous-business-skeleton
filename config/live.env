# Operationalization — the LIVE profile (PRD 0009 / ADR-0061).
#
# Flips the Phase-1 seams (whose real adapter already exists) from stub/sample to real, all at once.
# Source this before starting the console + services in a live deployment:  `set -a; . config/live.env`
#
# Every AB_<PORT>_PROVIDER defaults to "stub" when unset, so omit a line to keep that seam stubbed.

# Console read panels → live in-process reads (audit / kill-switch / experiments / products).
AB_CONSOLE_PROVIDER=live

# Console Propose → the live gateway as growth.experiment_design_agent (needs the Keycloak client +
# its Vault secret: `make seed-vault`).
AB_GROWTH_PORT_PROVIDER=http

# Console kill switch → the live governed kill-switch service (operator-signed).
AB_KILLSWITCH_PORT_PROVIDER=http

# Ideation → the eval-gated ModelGatewayIdeationModel (abstains safely → falls back to stub cards
# until a model is promoted for the `ideation` profile: `python -m ab_evals promote ideation`).
AB_IDEATION_PROVIDER=modelgateway

# Served model → Portkey (needs `uv sync --group models` + AB_PORTKEY_API_KEY). The ideation/
# product_spec adapters light up once you eval-promote it. Advisory seam, so not fail-closed.
# AB_MODEL_PROVIDER=portkey
# AB_PORTKEY_API_KEY=<from api-keys/portkey_api>

# Monitoring → the real exporter is `make monitor-submit` (Icinga2RestExporter; needs the monitoring
# compose profile + ICINGA2_API_PASSWORD). The console /metrics Prometheus rail is already live.

# AB_ENV: set to your real environment (not a dev value) so VULN-005 fail-closed secrets apply and any
# `critical` seam refuses to run on a stub. Then AB_PG_DSN / AB_OPERATOR_AUTH_SECRET / … must be set.
# AB_ENV=prod
